# Скопируй этот файл в .env и заполни своими ключами:
#   cp .env.example .env

# Токен бота из business.max.ru → Чат-боты → Интеграция → Получить токен
MAX_BOT_TOKEN=ВСТАВЬ_ТОКЕН_БОТА

# Адрес твоего сервера для webhook (HTTPS обязателен)
WEBHOOK_URL=https://ВАШ_IP_ИЛИ_ДОМЕН/webhook

# Ключ OpenAI из platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# Сколько сообщений помнит бот (история диалога)
HISTORY_LENGTH=20

# Как бот представляет себя и общается
SYSTEM_PROMPT=Ты умный и добрый помощник по имени Макс. Отвечай на русском языке, объясняй просто и понятно, как будто объясняешь близкому человеку. Будь вежливым и терпеливым.
