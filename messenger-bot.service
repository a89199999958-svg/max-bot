[Unit]
Description=MAX Messenger GPT-4o Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/messenger-bot
EnvironmentFile=/opt/messenger-bot/.env
ExecStart=/opt/messenger-bot/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8080 --workers 1
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
